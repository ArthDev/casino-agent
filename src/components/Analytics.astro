---
/**
 * Analytics component — supports GA4 and Plausible.
 * Controlled by PUBLIC_GA4_ID and PUBLIC_PLAUSIBLE_DOMAIN env vars.
 * GA4 loads only after cookie consent; Plausible is cookieless by default.
 */
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
---

{plausibleDomain && (
  <script
    defer
    data-domain={plausibleDomain}
    src="https://plausible.io/js/script.js"
    is:inline
  />
)}

{ga4Id && (
  <Fragment>
    <script id="ga4-loader" is:inline define:vars={{ ga4Id }}>
      // GA4 loads only when consent is granted
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', ga4Id, { send_page_view: false });

      window.__loadGA4 = function() {
        if (document.getElementById('ga4-script')) return;
        var s = document.createElement('script');
        s.id = 'ga4-script';
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + ga4Id;
        document.head.appendChild(s);
        gtag('consent', 'update', { analytics_storage: 'granted' });
        gtag('event', 'page_view');
      };
    </script>
  </Fragment>
)}
