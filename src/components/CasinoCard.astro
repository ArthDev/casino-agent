---
import RatingStars from './RatingStars.astro';

interface Props {
  name: string;
  slug: string;
  rating: number;
  bonus: string;
  description: string;
  affiliateUrl: string;
  logo?: string;
}

const { name, slug, rating, bonus, description, affiliateUrl, logo } = Astro.props;
---

<div class="rounded-xl border border-gray-800 bg-gray-900 p-6 transition-colors hover:border-amber-400/50">
  <div class="flex items-start justify-between gap-3">
    {logo && (
      <img
        src={logo}
        alt={`Logo ${name}`}
        width={48}
        height={48}
        loading="lazy"
        decoding="async"
        class="h-12 w-12 shrink-0 rounded-lg object-contain"
      />
    )}
    <h3 class="text-lg font-semibold">
      <a href={`/casinos/${slug}/`} class="hover:text-amber-400 transition-colors">
        {name}
      </a>
    </h3>
    <RatingStars rating={rating} />
  </div>
  <p class="mt-2 text-sm text-gray-400">{description}</p>
  <p class="mt-3 text-sm font-medium text-amber-400">{bonus}</p>
  <div class="mt-4 flex gap-3">
    <a
      href={`/casinos/${slug}/`}
      class="text-sm text-gray-300 hover:text-white transition-colors"
    >
      Lire l'avis
    </a>
    <a
      href={affiliateUrl}
      target="_blank"
      rel="noopener sponsored"
      class="rounded-lg bg-amber-400 px-4 py-1.5 text-sm font-semibold text-gray-950 hover:bg-amber-300 transition-colors"
    >
      Visiter
    </a>
  </div>
</div>
