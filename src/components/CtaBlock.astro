---
interface Props {
  title: string;
  description?: string;
  buttonText: string;
  href: string;
  sponsored?: boolean;
}

const { title, description, buttonText, href, sponsored = true } = Astro.props;
---

<div class="my-8 rounded-xl border border-amber-400/30 bg-gradient-to-r from-amber-400/5 to-amber-400/10 p-6 text-center">
  <h3 class="text-xl font-bold">{title}</h3>
  {description && <p class="mt-2 text-gray-400">{description}</p>}
  <a
    href={href}
    target="_blank"
    rel={`noopener${sponsored ? ' sponsored' : ''}`}
    class="mt-4 inline-block rounded-lg bg-amber-400 px-8 py-3 font-semibold text-gray-950 hover:bg-amber-300 transition-colors"
  >
    {buttonText}
  </a>
</div>
