---
const navItems = [
  { label: 'Accueil', href: '/' },
  { label: 'Casinos', href: '/casinos/' },
  { label: 'Guides', href: '/guides/' },
  { label: 'Bonus', href: '/bonus/' },
  { label: 'Comparatifs', href: '/comparatifs/' },
];
---

<header class="border-b border-gray-800 bg-gray-950/80 backdrop-blur-sm sticky top-0 z-50">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="text-xl font-bold text-white">
      Casino<span class="text-amber-400">Guide</span>
    </a>
    <button
      id="mobile-menu-btn"
      class="md:hidden text-gray-300 hover:text-white"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <ul class="hidden md:flex items-center gap-6">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="text-sm text-gray-300 hover:text-amber-400 transition-colors">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
  <ul id="mobile-menu" class="hidden border-t border-gray-800 px-4 pb-4 md:hidden">
    {navItems.map((item) => (
      <li>
        <a href={item.href} class="block py-2 text-sm text-gray-300 hover:text-amber-400">
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
