---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';

export async function getStaticPaths() {
  const casinos = await getCollection('casinos');
  return casinos.map((casino) => ({
    params: { slug: casino.data.slug },
    props: { casino },
  }));
}

const { casino } = Astro.props;
const { Content } = await render(casino);
const siteUrl = Astro.site?.origin ?? '';

const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: {
    '@type': 'Organization',
    name: casino.data.name,
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: casino.data.rating,
    bestRating: 5,
  },
  author: {
    '@type': 'Organization',
    name: 'CasinoGuide',
  },
  datePublished: casino.data.publishedAt.toISOString(),
  ...(casino.data.updatedAt
    ? { dateModified: casino.data.updatedAt.toISOString() }
    : {}),
};
---

<BaseLayout
  title={`${casino.data.name} - Avis et bonus | CasinoGuide`}
  description={casino.data.description}
>
  <SchemaMarkup schema={reviewSchema} />

  <article class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs
      items={[
        { label: 'Accueil', href: '/' },
        { label: 'Casinos', href: '/casinos/' },
        { label: casino.data.name },
      ]}
    />

    <header class="mt-6">
      <div class="flex items-start justify-between gap-4">
        <h1 class="text-3xl font-bold md:text-4xl">{casino.data.name}</h1>
        <span class="shrink-0 rounded-full bg-amber-400/10 px-3 py-1 text-lg font-bold text-amber-400">
          {casino.data.rating}/5
        </span>
      </div>
      <p class="mt-3 text-lg text-gray-400">{casino.data.description}</p>
      <div class="mt-4 rounded-lg border border-amber-400/30 bg-amber-400/5 p-4">
        <p class="font-medium text-amber-400">{casino.data.bonus}</p>
        <a
          href={casino.data.affiliateUrl}
          target="_blank"
          rel="noopener sponsored"
          class="mt-3 inline-block rounded-lg bg-amber-400 px-6 py-2 text-sm font-semibold text-gray-950 hover:bg-amber-300 transition-colors"
        >
          Visiter le casino
        </a>
      </div>
    </header>

    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      <div class="rounded-lg border border-green-800/50 bg-green-900/10 p-4">
        <h2 class="font-semibold text-green-400">Avantages</h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          {casino.data.pros.map((pro) => (
            <li class="flex gap-2">
              <span class="text-green-400">+</span> {pro}
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-lg border border-red-800/50 bg-red-900/10 p-4">
        <h2 class="font-semibold text-red-400">Inconvenients</h2>
        <ul class="mt-2 space-y-1 text-sm text-gray-300">
          {casino.data.cons.map((con) => (
            <li class="flex gap-2">
              <span class="text-red-400">-</span> {con}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="prose prose-invert mt-8 max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
