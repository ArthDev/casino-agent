---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const casinos = await getCollection('casinos');
const sorted = casinos.sort((a, b) => b.data.rating - a.data.rating);
---

<BaseLayout
  title="Meilleurs casinos en ligne - Avis et classement"
  description="Decouvrez notre classement des meilleurs casinos en ligne avec avis detailles, bonus et comparatifs."
>
  <div class="mx-auto max-w-6xl px-4 py-8">
    <Breadcrumbs items={[{ label: 'Accueil', href: '/' }, { label: 'Casinos' }]} />

    <h1 class="mt-6 text-3xl font-bold md:text-4xl">Meilleurs casinos en ligne</h1>
    <p class="mt-3 max-w-2xl text-gray-400">
      Notre selection des casinos les plus fiables, classes par note.
    </p>

    {sorted.length === 0 ? (
      <p class="mt-8 text-gray-500">Aucun casino reference pour le moment.</p>
    ) : (
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {sorted.map((casino) => (
          <a
            href={`/casinos/${casino.data.slug}/`}
            class="group rounded-xl border border-gray-800 bg-gray-900 p-6 transition-colors hover:border-amber-400/50"
          >
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold group-hover:text-amber-400">{casino.data.name}</h2>
              <span class="rounded-full bg-amber-400/10 px-2 py-1 text-sm font-medium text-amber-400">
                {casino.data.rating}/5
              </span>
            </div>
            <p class="mt-2 text-sm text-gray-400">{casino.data.description}</p>
            <p class="mt-3 text-sm font-medium text-amber-400">{casino.data.bonus}</p>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
