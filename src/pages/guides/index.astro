---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const guides = await getCollection('guides');
const sorted = guides.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<BaseLayout
  title="Guides casino en ligne - Conseils et strategies"
  description="Nos guides complets pour jouer au casino en ligne : regles, strategies, conseils de jeu responsable."
>
  <div class="mx-auto max-w-6xl px-4 py-8">
    <Breadcrumbs items={[{ label: 'Accueil', href: '/' }, { label: 'Guides' }]} />

    <h1 class="mt-6 text-3xl font-bold md:text-4xl">Guides casino</h1>
    <p class="mt-3 max-w-2xl text-gray-400">
      Tout ce que vous devez savoir pour jouer en ligne.
    </p>

    {sorted.length === 0 ? (
      <p class="mt-8 text-gray-500">Aucun guide publie pour le moment.</p>
    ) : (
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {sorted.map((guide) => (
          <a
            href={`/guides/${guide.data.slug}/`}
            class="group rounded-xl border border-gray-800 bg-gray-900 p-6 transition-colors hover:border-amber-400/50"
          >
            <span class="text-xs font-medium uppercase tracking-wider text-amber-400">
              {guide.data.category}
            </span>
            <h2 class="mt-2 text-lg font-semibold group-hover:text-amber-400">
              {guide.data.title}
            </h2>
            <p class="mt-2 text-sm text-gray-400">{guide.data.description}</p>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
