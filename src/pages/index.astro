---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Casino en ligne - Comparatif et avis des meilleurs casinos"
  description="Trouvez les meilleurs casinos en ligne avec nos avis d'experts, comparatifs et bonus exclusifs."
>
  <main class="mx-auto max-w-5xl px-4 py-16">
    <h1 class="text-4xl font-bold">Meilleurs casinos en ligne 2026</h1>
    <p class="mt-4 text-lg text-gray-400">
      Comparatif, avis et bonus exclusifs des casinos les plus fiables.
    </p>
  </main>
</BaseLayout>
