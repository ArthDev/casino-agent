---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

const siteUrl = Astro.site?.origin ?? '';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'CasinoGuide',
  url: siteUrl,
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'CasinoGuide',
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  description: 'Comparatif et avis des meilleurs casinos en ligne en France.',
  sameAs: [],
};
---

<BaseLayout
  title="Casino en ligne - Comparatif et avis des meilleurs casinos"
  description="Trouvez les meilleurs casinos en ligne avec nos avis d'experts, comparatifs et bonus exclusifs."
>
  <SchemaMarkup schema={websiteSchema} />
  <SchemaMarkup schema={organizationSchema} />

  <section class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="text-4xl font-bold md:text-5xl">
      Meilleurs casinos en ligne <span class="text-amber-400">2026</span>
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-gray-400">
      Comparatif, avis et bonus exclusifs des casinos les plus fiables.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-16">
    <h2 class="text-2xl font-bold">Top casinos</h2>
    <p class="mt-2 text-gray-400">Les avis seront affiches ici une fois le contenu ajoute.</p>
  </section>
</BaseLayout>
